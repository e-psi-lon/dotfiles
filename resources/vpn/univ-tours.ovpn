dev tun
persist-tun
persist-key
data-ciphers AES-128-GCM:AES-256-GCM:CHACHA20-POLY1305:AES-256-CBC
data-ciphers-fallback AES-256-CBC
auth SHA512
tls-client
client
resolv-retry infinite
remote vpnfr-etu.univ-tours.fr 443 tcp4
nobind
remote-cert-tls server
auth-nocache
reneg-sec 0

config /run/secrets/univ-tours.ovpn